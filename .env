WINDOW_RESOLUTION=1280x960

# --- CAMERA CONFIGURATION ---
FRAME_RATE=10
CAMERA_RESOLUTION=640x480
UPSCALE_FACTOR=2.0

# --- MANUAL CENTER CONFIGURATION ---
TARGET_CENTER_X=320.0
TARGET_CENTER_Y=240.0

# --- LINK BETWEEN RL AND PIXELS --- (PLATE_WIDTH_PIXELS should be equal to camera height if it perfectly fits)
PLATE_WIDTH_PIXELS=480
PLATE_PHYSICAL_SIZE_CM=40

# --- PID PARAMETERS ---
PID_KP=1.5
PID_KI=0.0
PID_KD=0.3

INVERT_X=true
INVERT_Y=true

# --- BALL PARAMETERS ---
# Color mask to isolate the orange ball
BALL_LOWER_COLOR="hsv(10, 80%, 60%)"
BALL_HIGHER_COLOR="hsv(30, 100%, 100%)"

#BALL_LOWER_COLOR="hsv(0, 70%, 45%)"
#BALL_HIGHER_COLOR="hsv(5, 80%, 60%)"

# --- ARDUINO PORT ---
#USB_PORT=COM4
USB_PORT=/dev/ttyACM0

USB_BAUD_RATE=115200

# --- PISTON DIMENSIONS ---
ARM=3.5
ROD=14.0

# --- GRAPH ---
GRAPH_HEIGHT=100
GRAPH_WIDTH=200