FRAME_RATE=10
RESOLUTION=640x480

# --- MANUAL CENTER CONFIGURATION ---
# Coordinates (X, Y) in pixels of your plate's center on the screen
# (Adjust manually by placing the ball in the center and reading the console)
TARGET_CENTER_X=320.0
TARGET_CENTER_Y=240.0

# Estimated width of your plate on the screen in pixels
# (Allows the PID to convert pixels into centimeters, your plate is 40x40 cm)
PLATE_WIDTH_PIXELS=480.0
PLATE_PHYSICAL_SIZE_CM=40

# --- PID PARAMETERS ---
PID_KP=1.5
PID_KI=0.0
PID_KD=0.3

INVERT_X=true
INVERT_Y=true

# --- BALL PARAMETERS ---
# Color mask to isolate the orange ball
BALL_LOWER_COLOR="hsv(10, 80%, 60%)"
BALL_HIGHER_COLOR="hsv(30, 100%, 100%)"

# Option for a red ball (uncomment if needed)
#BALL_LOWER_COLOR="hsv(0, 70%, 45%)"
#BALL_HIGHER_COLOR="hsv(5, 80%, 60%)"

RADIUS=30

# Windows
#USB_PORT=COM4
# WSL
USB_PORT=/dev/ttyACM0

USB_BAUD_RATE=115200

# --- PISTON DIMENSIONS ---
ARM=3.5
ROD=14.0