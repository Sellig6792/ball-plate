FRAME_RATE=10
RESOLUTION=640x480

# --- CONFIGURATION MANUELLE DU CENTRE ---
# Coordonnées (X, Y) en pixels du centre de ta plaque à l'écran
# (À ajuster manuellement en posant la bille au centre et en lisant la console)
TARGET_CENTER_X=320.0
TARGET_CENTER_Y=240.0

# Largeur estimée de ta plaque à l'écran en pixels
# (Permet au PID de convertir les pixels en centimètres, ta plaque fait 40x40 cm)
PLATE_WIDTH_PIXELS=450.0

# --- PARAMÈTRES DU PID ---
PID_KP=1.5
PID_KI=0.0
PID_KD=0.3

# --- PARAMÈTRES DE LA BILLE ---
# Masque de couleur pour isoler ta bille orange
BALL_LOWER_COLOR="hsv(10, 80%, 60%)"
BALL_HIGHER_COLOR="hsv(30, 100%, 100%)"
RADIUS=30

USB_PORT=/dev/ttyACM0
USB_BAUD_RATE=115200